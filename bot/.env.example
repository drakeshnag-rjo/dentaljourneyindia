# ==============================================
# DentalJourneyIndia Bot — Environment Variables
# ==============================================

# Telegram Bot Token (from @BotFather)
TELEGRAM_BOT_TOKEN=your-telegram-bot-token-here

# Ollama Configuration
# Set this to the IP of your Ollama machine
OLLAMA_URL=http://192.168.1.XXX:11434
OLLAMA_MODEL=qwen3:0.6b

# Twenty CRM Configuration
TWENTY_CRM_URL=http://localhost:3000
TWENTY_API_KEY=your-twenty-api-key-here

# Web API port (for website lead capture)
WEB_API_PORT=3001

# Node environment
NODE_ENV=production
